{
  "compilerOptions": {
    // File Layout
     "rootDir": "./src",
     "outDir": "./dist",

    "paths": {
      "#types/*.js": ["./src/@types/*.ts"],
      "#config/*.js": ["./src/config/*.ts"],
      "#database/*.js": ["./src/database/*.ts"],
      "#middlewares/*.js": ["./src/middlewares/*.ts"],
      "#services/*.js": ["./src/services/*.ts"],
      "#controllers/*.js": ["./src/controllers/*.ts"],
      "#routes/*.js": ["./src/routes/*.ts"],
      "#validators/*.js": ["./src/validators/*.ts"],
      "#utils/*.js": ["./src/utils/*.ts"]
    },

    // Environment Settings
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "lib": ["esnext"],
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
